{
  "languages": {
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "language_servers": [
        "!deno",
        "typescript-language-server",
        "!vtsls",
        "eslint",
      ],
      "formatter": "prettier",
    },
    "JSON": {
      "language_servers": ["eslint", "json-language-server"],
    },
    "JSONC": {
      "language_servers": ["eslint", "json-language-server"],
    },
    "Markdown": {
      "format_on_save": "on",
      "formatter": "prettier",
    },
    "TSX": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "language_servers": [
        "!deno",
        "typescript-language-server",
        "!vtsls",
        "eslint",
      ],
      "formatter": "prettier",
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "language_servers": [
        "!deno",
        "typescript-language-server",
        "!vtsls",
        "eslint",
      ],
      "formatter": "prettier",
    },
  },
  "lsp": {
    "eslint": {
      "enable_lsp_tasks": true,
      "settings": {
        "workingDirectory": {
          "mode": "auto",
        },
      },
    },
  },
}
